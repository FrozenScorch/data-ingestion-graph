# =============================================================================
# Ingestion Graph - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# Application
APP_NAME=enterprise-data-ingestion-graph-studio
APP_ENV=development
APP_DEBUG=true
APP_PORT=8040

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://ingestion:ingestion_password@localhost:5432/ingestion_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://:redis_secret_change_me@localhost:6379/0
REDIS_PASSWORD=redis_secret_change_me

# JWT Authentication
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# Independent key used to encrypt saved connector credentials at rest.
# Required outside development; use a random value of at least 32 characters.
CONNECTION_ENCRYPTION_KEY=change-this-connection-encryption-key

# Admin user (seeded on first startup)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ingestion-graph.local
ADMIN_PASSWORD=admin123

# OpenRouter API
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Free models for testing (enforced constraint - NEVER use paid models without approval)
OPENROUTER_FREE_MODELS=z-ai/glm-4.5-air:free,qwen/qwen3.5-9b

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8040

# File storage
UPLOAD_DIR=./data/uploads
TEMP_DIR=./data/temp
MAX_UPLOAD_SIZE_MB=100

# Logging
LOG_LEVEL=INFO
