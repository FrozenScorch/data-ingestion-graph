# Generate a real .env instead of using these placeholders:
#   python scripts/init_lan_env.py --host 192.168.1.50
# Add --tls to use Caddy's private LAN certificate authority.

STUDIO_HOSTNAME=192.168.1.50
STUDIO_ORIGIN=http://192.168.1.50:8040
STUDIO_BIND=0.0.0.0
STUDIO_PORT=8040
STUDIO_HTTPS_PORT=8443
CADDY_CONFIG=Caddyfile.http

# Required secrets. The generator creates independent high-entropy values.
POSTGRES_PASSWORD=replace-with-generated-value
REDIS_PASSWORD=replace-with-generated-value
JWT_SECRET_KEY=replace-with-generated-value-at-least-32-characters
CONNECTION_ENCRYPTION_KEY=replace-with-generated-value-at-least-32-characters
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ingestion-graph.local
ADMIN_PASSWORD=replace-with-generated-value

OPENROUTER_API_KEY=
QUERY_ARTIFACT_TTL_HOURS=168
RUN_WORKER_CONCURRENCY=1
RUN_WORKER_POLL_SECONDS=1
RUN_WORKER_LEASE_SECONDS=60
RUN_WORKER_HEARTBEAT_SECONDS=15
TRIGGER_SCHEDULER_ENABLED=true
TRIGGER_SCHEDULER_POLL_SECONDS=5
TRIGGER_SCHEDULER_BATCH_SIZE=50
WEBHOOK_MAX_BYTES=1048576
WEBHOOK_TIMESTAMP_SKEW_SECONDS=300
WEBHOOK_DELIVERY_RETENTION_HOURS=168
WEBHOOK_PRUNE_INTERVAL_SECONDS=3600

# Outbound requests allow public IPs by default and pin validated DNS answers.
# Add exact hosts/CIDRs only for intentional private-LAN connector targets.
EGRESS_POLICY_MODE=public
EGRESS_ALLOWED_HOSTS=
EGRESS_ALLOWED_CIDRS=
EGRESS_MAX_REDIRECTS=3
LOG_LEVEL=INFO
